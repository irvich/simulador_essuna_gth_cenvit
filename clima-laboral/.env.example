# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a git (ya está en .gitignore).
#
# Cómo obtener estas claves:
#   1. supabase.com → tu proyecto → Project Settings → API
#   2. Copia "Project URL" y "anon public key"

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_ADMIN_PASSWORD=cambia-esta-contraseña-antes-de-produccion
